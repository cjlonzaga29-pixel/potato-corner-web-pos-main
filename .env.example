# ---- App URLs ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
API_PORT=4000

# ---- Database (Supabase Postgres) ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/potato_corner_dev
DIRECT_URL=postgresql://postgres:password@localhost:5432/potato_corner_dev

# ---- Supabase ----
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# ---- Auth (JWT RS256) ----
JWT_PRIVATE_KEY=placeholder-rsa-private-key-pem
JWT_PUBLIC_KEY=placeholder-rsa-public-key-pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d
# Required at boot (config/index.ts's zod schema, min 32 chars) even though
# refresh tokens are opaque random strings, not JWTs — this value is never
# actually read by the auth flow. It exists only so the schema fails fast
# if it's absent; any random string >=32 chars satisfies it.
JWT_REFRESH_SECRET=placeholder-at-least-32-characters-long

# ---- Encryption (app-layer AES-256-GCM for government ID fields) ----
ENCRYPTION_KEY=placeholder-32-byte-base64-key

# ---- Redis / BullMQ (Upstash) ----
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ---- Email (Resend or SMTP) ----
RESEND_API_KEY=placeholder-resend-key
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=placeholder
SMTP_PASSWORD=placeholder
EMAIL_FROM=no-reply@potatocorner.local

# ---- Sentry ----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ---- PostHog ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ---- Misc ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Testing ----
# Gate every *.integration.test.ts file's canRunIntegrationTests check.
# Without these set, integration tests skip (not fail) — that's why all 60
# of them currently show as skipped rather than run. Point at a disposable
# test database/Redis instance, never a real dev/staging/production one.
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/potato_corner_test
TEST_REDIS_URL=redis://localhost:6379/1
