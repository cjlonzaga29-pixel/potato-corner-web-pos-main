# ---- App URLs ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
API_PORT=4000

# ---- Database (Supabase Postgres) ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/potato_corner_dev
DIRECT_URL=postgresql://postgres:password@localhost:5432/potato_corner_dev

# ---- Supabase ----
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# ---- Auth (JWT RS256) ----
JWT_PRIVATE_KEY=placeholder-rsa-private-key-pem
JWT_PUBLIC_KEY=placeholder-rsa-public-key-pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# ---- Encryption (app-layer AES-256-GCM for government ID fields) ----
ENCRYPTION_KEY=placeholder-32-byte-base64-key

# ---- Redis / BullMQ (Upstash) ----
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ---- Email (Resend or SMTP) ----
RESEND_API_KEY=placeholder-resend-key
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=placeholder
SMTP_PASSWORD=placeholder
EMAIL_FROM=no-reply@potatocorner.local

# ---- Sentry ----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ---- PostHog ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ---- Misc ----
NODE_ENV=development
LOG_LEVEL=debug
